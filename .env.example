LLM_PROVIDER=openai
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

OPENAI_API_KEY=your openai api key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=gpt-4o-2024-08-06

GEMINI_API_KEY=your gemini api key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=models/your-gemini-model-name

ANTHROPIC_API_KEY=your anthropic api key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=models/your-anthropic-model-name
ANTHROPIC_VERSION=2023-06-01

NVIDIA_API_KEY=your nvidia api key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=models/your-nvidia-model-name

CUSTOM_PROVIDER_TYPE=openai
CUSTOM_API_KEY=your custom api key
CUSTOM_BASE_URL=your custom base url
CUSTOM_MODEL=your custom model name
CUSTOM_ANTHROPIC_VERSION=2023-06-01

GITHUB_TOKEN=your github token
GITHUB_REPO_OWNER=your github repo owner
REPO_FILE_LIMIT=24
REPO_FILE_BYTES=6000
REPO_CONTEXT_BYTES=90000

VITE_API_BASE_URL=

